DJANGO_SECRET_KEY=change-me-babifix-admin
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Données factices (Marie Dubois, RES-001, comptes *_demo) : uniquement si =1
# BABIFIX_ENABLE_DEMO_SEED=1

# Temps réel multi-instances / production : broker Redis pour Django Channels
# REDIS_URL=redis://127.0.0.1:6379/1

# Push FCM — copiez ce fichier en .env et renseignez le chemin absolu du JSON Admin SDK
# FIREBASE_CREDENTIALS_JSON_PATH=C:/Users/VOTRE_USER/Downloads/babifix-firebase-adminsdk-xxxxx.json

# PostgreSQL (production) — si POSTGRES_DB est défini, SQLite et MySQL sont ignorés
# POSTGRES_DB=babifix
# POSTGRES_USER=babifix
# POSTGRES_PASSWORD=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# MySQL (WAMP / phpMyAdmin) — si MYSQL_DATABASE est défini, SQLite est ignoré (PostgreSQL reste prioritaire si POSTGRES_DB est défini)
# Créez la base dans phpMyAdmin : utf8mb4_unicode_ci (voir docs/WAMP_MYSQL.md)
# MYSQL_DATABASE=babifix
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306

# ─── Email transactionnel ─────────────────────────────────────────────────────
# EMAIL_HOST=smtp.mailjet.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-api-key
# EMAIL_HOST_PASSWORD=your-secret-key
# DEFAULT_FROM_EMAIL=BABIFIX <noreply@babifix.ci>

# ─── CinetPay (paiement Mobile Money) ────────────────────────────────────────
# CINETPAY_APIKEY=your-cinetpay-api-key
# CINETPAY_SITE_ID=your-cinetpay-site-id
# CINETPAY_NOTIFY_URL=https://api.babifix.ci/api/paiements/cinetpay/webhook/
# CINETPAY_RETURN_URL=https://babifix.ci/paiement-retour/
# CINETPAY_WEBHOOK_SECRET=your-webhook-hmac-secret

# ─── Sentry (monitoring erreurs production) ───────────────────────────────────
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
