# =============================================
# BABIFIX - Configuration environnement
# =============================================

# =============================================
# EMAIL SMTP (Gmail, Mailjet, SendGrid, etc.)
# =============================================
# Utiliser console.EmailBackend en dev local
# Changer vers smtp.EmailBackend en prod

# Gmail (gratuit, 100 emails/jour)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-app
DEFAULT_FROM_EMAIL=BABIFIX <contact@babifix.ci>

# =============================================
# APPLE SIGN-IN (nécessite Apple Developer $99/an)
# =============================================
APPLE_BUNDLE_ID=com.babifix.client.app
APPLE_TEAM_ID=VOTRE_TEAM_ID
APPLE_KEY_ID=VOTRE_KEY_ID
APPLE_PRIVATE_KEY=VOTRE_CLE_Privee_Sans_SautDeLigne