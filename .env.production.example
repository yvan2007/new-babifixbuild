# =============================================================================
# BABIFIX — Template variables d'environnement (PRODUCTION)
# =============================================================================
# Copier ce fichier vers .env et remplir les valeurs réelles
# ⚠️ NE JAMAIS commiter ce fichier avec des valeurs réelles !
# =============================================================================

# -----------------------------------------------------------------------------
# DJANGO BACKEND
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=changeme-generate-with-openssl-rand-hex-64
DJANGO_DEBUG=False
DJANGO_ENV=production
DJANGO_ALLOWED_HOSTS=babifix.ci,api.babifix.ci,www.babifix.ci

# Database (PostgreSQL recommandé en production)
POSTGRES_DB=babifix_prod
POSTGRES_USER=babifix_prod
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (pour WebSockets et cache)
REDIS_URL=redis://localhost:6379/0

# Email (SMTP production)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mailjet.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=changeme-mailjet-api-key
EMAIL_HOST_PASSWORD=changeme-mailjet-api-secret
DEFAULT_FROM_EMAIL=BABIFIX <contact@babifix.ci>

# -----------------------------------------------------------------------------
# CORS (Origins autorisés)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://babifix.ci,https://www.babifix.ci,https://api.babifix.ci

# -----------------------------------------------------------------------------
# SOCIAL AUTH (Google)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=changeme-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=changeme-google-client-secret

# -----------------------------------------------------------------------------
# CINETPAY (Mobile Money Côte d'Ivoire)
# -----------------------------------------------------------------------------
CINETPAY_APIKEY=changeme-cinetpay-apikey
CINETPAY_SITE_ID=changeme-cinetpay-site-id
CINETPAY_NOTIFY_URL=https://api.babifix.ci/api/paiements/cinetpay/webhook/
CINETPAY_RETURN_URL=https://babifix.ci/payment/result/

# -----------------------------------------------------------------------------
# SENTRY (Monitoring erreurs)
# -----------------------------------------------------------------------------
SENTRY_DSN=https://changeme@sentry.io/changeme

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
BABIFIX_THROTTLE_LOGIN_RATE=5
BABIFIX_THROTTLE_LOGIN_WINDOW=60

# -----------------------------------------------------------------------------
# FIREBASE (FCM)
# -----------------------------------------------------------------------------
# Voir console Firebase pour les valeurs
FIREBASE_PROJECT_ID=changeme
FIREBASE_PRIVATE_KEY=changeme
FIREBASE_CLIENT_EMAIL=changeme@changeme.iam.gserviceaccount.com

# -----------------------------------------------------------------------------
# FLUTTER APPS (URLs API)
# -----------------------------------------------------------------------------
BABIFIX_API_BASE=https://api.babifix.ci
BABIFIX_WS_BASE=wss://api.babifix.ci/ws
