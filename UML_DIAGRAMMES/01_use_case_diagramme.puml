@startuml BABIFIX - Diagramme de Cas d'Utilisation
!theme plain
skinparam backgroundColor #E3F2FD
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam defaultFontName Segoe UI
skinparam defaultFontSize 11
skinparam titleFontSize 14
skinparam titleFontColor #01579B

skinparam rectangle {
  BackgroundColor #BBDEFB
  BorderColor #1976D2
  FontColor #01579B
}

skinparam usecase {
  BackgroundColor #E3F2FD
  BorderColor #42A5F5
  FontColor #01579B
}

skinparam actor {
  BackgroundColor #90CAF9
  BorderColor #1976D2
}

skinparam arrow {
  Color #64B5F6
  FontColor #01579B
}

title **BABIFIX** - Diagramme de Cas d'Utilisation Complet\nPlateforme de Services à Domicile

' ==================== ACTEURS ====================
actor "Client" as Client
actor "Prestataire" as Prestataire
actor "Admin" as Admin

' ==================== SYSTÈME BABIFIX ====================
rectangle "BABIFIX - Application Client" as AppClient {
  usecase "S'inscrire" as UC01
  usecase "Se connecter" as UC02
  usecase "Consulter les catégories" as UC03
  usecase "Explorer sans connexion" as UC04
  usecase "Choisir un prestataire" as UC05
  usecase "Créer une demande" as UC06A
  usecase "Recevoir un devis" as UC06B
  usecase "Accepter/Refuser devis" as UC06C
  usecase "Réserver une prestation" as UC06
  usecase "Payer (Mobile Money)" as UC07
  usecase "Valider la prestation" as UC07B
  usecase "Noter et commenter" as UC08
  usecase "Consulter historique" as UC09
  usecase "Chatter avec prestataire" as UC10
  usecase "Consulter profil prestataire" as UC11
  usecase "Annuler réservation" as UC12
  usecase "Signaler un problème" as UC13
  usecase "Ajouter aux favoris" as UC14
  usecase "Consulter notifications" as UC15
  usecase "Activer biométrie" as UC16
  usecase "Ouvrir un litige" as UC17
  usecase "Voir sur la carte" as UC18
}

rectangle "BABIFIX Pro - Application Prestataire" as AppPro {
  usecase "S'inscrire (formulaire CNI)" as UC20
  usecase "Se connecter" as UC21
  usecase "Gérer son profil" as UC22
  usecase "Consulter demandes clients" as UC23A
  usecase "Consulter rendez-vous" as UC23
  usecase "Créer un devis" as UC23B
  usecase "Confirmer paiement espèces" as UC24
  usecase "Suivre ses gains" as UC25
  usecase "Recevoir notifications" as UC26
  usecase "Accepter/Refuser demande" as UC27
  usecase "Démarrer intervention" as UC27B
  usecase "Terminer intervention" as UC27C
  usecase "Chatter avec client" as UC28
  usecase "Consulter statistiques personnelles" as UC29
  usecase "Mettre à jour disponibilités" as UC30
  usecase "Déclarer indisponibilité" as UC31
  usecase "Gérer son portfolio" as UC32
  usecase "Noter le client" as UC33
}

rectangle "BABIFIX Admin - Panel Gestionnaire" as AppAdmin {
  usecase "Valider prestataires" as UC40
  usecase "Visualiser statistiques" as UC41
  usecase "Gérer catégories" as UC42
  usecase "Envoyer notifications" as UC43
  usecase "Gérer paiements espèces" as UC44
  usecase "Gérer utilisateurs" as UC45
  usecase "Consulter revenus" as UC46
  usecase "Mettre à jour contenu dynamique" as UC47
  usecase "Gérer FAQ" as UC48
  usecase "Voir toutes les données" as UC49
  usecase "Exporter données CSV" as UC50
  usecase "Actions bulk (valider/refuser)" as UC51
  usecase "Consulter journal d'audit" as UC52
  usecase "Gérer commissions par catégorie" as UC53
}

