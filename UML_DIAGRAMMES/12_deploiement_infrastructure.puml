@startuml BABIFIX - Diagramme de Déploiement
!theme plain

skinparam backgroundColor #E3F2FD
skinparam nodeStyle rectangle

skinparam rectangle {
  BackgroundColor #BBDEFB
  BorderColor #1976D2
  FontColor #01579B
}

skinparam node {
  BackgroundColor #C8E6C9
  BorderColor #2E7D32
  FontColor #1B5E20
}

skinparam artifact {
  BackgroundColor #FFE082
  BorderColor #FF8F00
}

skinparam arrow {
  Color #64B5F6
}

title **BABIFIX** - Diagramme de Déploiement\nInfrastructure Production

node "Client Devices" {
  artifact "BABIFIX Client App\n(Flutter iOS)" as iOSClient
  artifact "BABIFIX Client App\n(Flutter Android)" as AndroidClient
  artifact "BABIFIX Pro App\n(Flutter iOS)" as iOSPro
  artifact "BABIFIX Pro App\n(Flutter Android)" as AndroidPro
  artifact "BABIFIX Admin Panel\n(Django Templates + HTMX)" as WebAdmin
  artifact "Browser\n(Vitrine Django)" as Browser
}

node "CDN / Edge Network" {
  node "Cloudflare" {
    artifact "SSL Termination"
    artifact "DDoS Protection"
    artifact "Static Assets CDN"
  }
}

node "Load Balancer" {
  artifact "Nginx\n(reverse proxy)"
  artifact "Health Checks"
}

node "Application Servers" {
  node "Server 1 (App)" {
    artifact "Gunicorn / Daphne"
    artifact "Django API + Admin"
    artifact "Channels (ASGI)"
  }
  
  node "Server 2 (App)" {
    artifact "Gunicorn / Daphne"
    artifact "Django API + Admin"
    artifact "Channels (ASGI)"
  }
}

node "WebSocket Server" {
  artifact "Daphne"
  artifact "Django Channels\n(Redis Layer)"
}

node "Database" {
  node "PostgreSQL" {
    artifact "PostgreSQL 16\n(Single/Master-Slave)" as PG
  }
}

node "Cache / Message Queue" {
  artifact "Redis\n(Cache + WS + Celery)" as Redis
}

node "Object Storage" {
  artifact "Local / S3 / MinIO\n(Media files)" as Storage
}

node "Monitoring" {
  artifact "Sentry\n(Error Tracking)"
  artifact "Grafana\n(Metrics)"
}

node "External Services" {
  artifact "Firebase FCM\n(Push Notifications)" as FCM
  artifact "CinetPay API\n(Paiements Mobile Money)"
  artifact "SMTP / SendGrid\n(Emails)"
}

' Connections
iOSClient -down-> Cloudflare : HTTPS
AndroidClient -down-> Cloudflare
iOSPro -down-> Cloudflare
AndroidPro -down-> Cloudflare
WebAdmin -down-> Cloudflare
Browser -down-> Cloudflare

Cloudflare -down-> Nginx
Nginx -down-> "Server 1 (App)" : HTTP/2
Nginx -down-> "Server 2 (App)"

"Server 1 (App)" -down-> PG
"Server 2 (App)" -down-> PG

"Server 1 (App)" -down-> Redis
"Server 2 (App)" -down-> Redis

"Server 1 (App)" -down-> Storage
"Server 2 (App)" -down-> Storage

"Server 1 (App)" -left-> "WebSocket Server"
"Server 2 (App)" -left-> "WebSocket Server"
"WebSocket Server" -down-> Redis

"Server 1 (App)" -down-> FCM : FCM HTTP API (push only)
"Server 2 (App)" -down-> FCM

"Server 1 (App)" -down-> CinetPay : API REST
"Server 2 (App)" -down-> CinetPay

"Server 1 (App)" -down-> SMTP : SendGrid/SMTP

"Server 1 (App)" -down-> Sentry
"Server 2 (App)" -down-> Sentry
"Server 1 (App)" -down-> Grafana

note bottom of WebAdmin
  Django Templates + HTMX
  Pas de Flutter Web
  Sessions Django + CSRF
end note

note bottom of FCM
  Firebase Firebase Cloud Messaging
  UNIQUEMENT pour les notifications push
  Pas de Firebase Auth (JWT Django)
end note

note bottom of PG
  PostgreSQL 16
  WAL Streaming Replication (si cluster)
  Automated Backups (daily)
end note

@enduml