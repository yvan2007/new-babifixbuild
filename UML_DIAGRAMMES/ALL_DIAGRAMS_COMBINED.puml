title **BABIFIX** - Diagramme de Classes - Modèle de Domaine (Nouveau Flux)

' ==================== CLASSE UTILISATEUR (ABSTRACT) ====================
abstract class Utilisateur {
  - id: String
  - email: String
  - telephone: String
  - nom: String
  - prenom: String
  - photoUrl: String
  - dateCreation: DateTime
  - dateModification: DateTime
  - actif: Boolean
  --
  + getId(): String
  + getEmail(): String
  + setEmail(email: String): void
  + getTelephone(): String
  + setTelephone(tel: String): void
  + getNomComplet(): String
  + getPhotoUrl(): String
  + setPhotoUrl(url: String): void
  + isActif(): Boolean
  + setActif(actif: Boolean): void
}

' ==================== CLASSE CLIENT ====================
class Client {
  - clientId: String
  - adresse: String
  - ville: String
  - pointsFidelite: int
  - parrainCode: String
  - parrainPar: String
  - depense: double
  --
  + getAdresse(): String
  + setAdresse(adresse: String): void
  + getPointsFidelite(): int
  + ajouterPoints(points: int): void
  + getParrainCode(): String
  + reserver(prestataire: Prestataire, service: Service, date: DateTime): Reservation
  + noter(prestataire: Prestataire, note: int, commentaire: String): Rating
  + payer(reservation: Reservation, montant: double): Paiement
}

' ==================== CLASSE PRESTATAIRE ====================
class Prestataire {
  - prestataireId: String
  - specialite: String
  - description: String
  - cniUrl: String
  - statutValidation: StatutValidation
  - dateValidation: DateTime
  - tarifHoraire: double
  - disponible: Boolean
  - noteMoyenne: double
  - nombreAvis: int
  - category: Categorie
  --
  + getSpecialite(): String
  + setSpecialite(spec: String): void
  + getDescription(): String
  + getCniUrl(): String
  + getStatutValidation(): StatutValidation
  + setStatutValidation(statut: StatutValidation): void
  + getTarifHoraire(): double
  + setTarifHoraire(tarif: double): void
  + isDisponible(): Boolean
  + getNoteMoyenne(): double
  + creerDevis(reservation: Reservation): Devis
  + accepterReservation(reservation: Reservation): void
  + refuserReservation(reservation: Reservation): void
  + confirmerPaiementEspeces(reservation: Reservation): void
}

' ==================== CLASSE ADMIN ====================
class Admin {
  - adminId: String
  - niveauAcces: int
  --
  + validerPrestataire(prestataire: Prestataire): void
  + refuserPrestataire(prestataire: Prestataire, motif: String): void
  + creerCategorie(categorie: Categorie): void
  + supprimerCategorie(categorie: Categorie): void
  + envoyerNotification(destinataires: List, message: String): void
  + validerPaiementEspeces(paiement: Paiement): void
  + consulterStatistiques(): Statistiques
}

' ==================== ÉNUMÉRATIONS ====================
enum StatutValidation {
  PENDING
  VALIDE
  REFUSE
  SUSPENDU
}

enum StatutReservation {
  DEMANDE_ENVOYEE
  DEVIS_EN_COURS
  DEVIS_ENVOYE
  DEVIS_ACCEPTE
  INTERVENTION_EN_COURS
  EN_ATTENTE_CLIENT
  TERMINEE
  ANNULEE
}

enum StatutPaiement {
  PENDING
  COMPLETE
  DISPUTE
  REFUND
}

enum TypePaiement {
  MOBILE_MONEY
  ESPECES
  CARTE
  AUTRE
}

enum StatutDevis {
  BROUILLON
  ENVOYE
  ACCEPTE
  REFUSE
  EXPIRE
}

enum TypeLigneDevis {
  FOURNITURE
  MAIN_OEUVRE
  DEPLACEMENT
  AUTRE
}

