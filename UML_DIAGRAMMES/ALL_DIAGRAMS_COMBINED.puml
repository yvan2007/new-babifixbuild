:Acceder au Panel Admin (Django Templates + HTMX);
:Se connecter via Sessions Django + CSRF;

|Systeme|
:Vérifier que role = "admin";

if (Acces autorise ?) then (oui)
  :Acces accorde au dashboard;
else (non)
  :Redirection vers page de login;
  stop
endif

|Admin|
:Afficher Dashboard principal;

fork
  partition "Validation Prestataires" {
    :Menu "Prestataires en attente";
    :Charger liste des prestataires avec statut PENDING;
    :Selectionner un dossier;
    :Examiner photo CNI + informations saisies;
    
    if (Decision ?) then (Valider)
      :Cliquer "Approuver";
      |Systeme|
      :Mettre a jour provider.statut = "VALIDE";
      :Mettre a jour provider.is_approved = true;
      :Envoyer notification FCM "Compte valide";
    else (Refuser)
      :Saisir motif de refus obligatoire;
      :Cliquer "Refuser";
      |Systeme|
      :Mettre a jour provider.statut = "REFUSE";
      :Enregistrer refusal_reason;
      :Envoyer notification FCM "Demande refusee : [motif]";
    endif
  }
end fork

fork again
  partition "Gestion Categories" {
    :Menu "Categories";
    
    if (Action souhaitee ?) then (Creer nouvelle)
      :Ouvrir formulaire creation;
      :Remplir nom, description, icone, ordre d'affichage;
      |Systeme|
      :INSERT INTO category (nom, description, icone_slug, ordre_affichage, actif);
    elseif (Modifier existante)
      :Selectionner categorie;
      :Modifier nom / description / icone / ordre;
      |Systeme|
      :UPDATE category SET ...;
    else (Desactiver / Supprimer)
      :Selectionner categorie;
      :Cliquer "Desactiver";
      |Systeme|
      :UPDATE category SET actif = false;
      :Categorie devient invisible pour les clients;
    endif
  }
end fork

fork again
  partition "Statistiques & Rapports" {
    :Menu "Statistiques";
    |Systeme|
    :Requetes SQL agregees (reservations, paiements, utilisateurs);
    :Calculer revenus totaux, commissions BABIFIX, CA;
    :Calculer nombre de reservations (par statut, par periode);
    :Calculer utilisateurs actifs, prestataires valides;
    :Generer graphiques et KPIs avec HTMX;
    |Admin|
    :Consulter / exporter rapports CSV;
  }
end fork

fork again
  partition "Validation Paiements Espaces" {
    :Menu "Paiements en attente (especes)";
    :Charger liste des reservations TERMINEE avec paiement ESPECES non valide;
    :Consulter details reservation + declarations client/prestataire;
    
    if (Valider paiement ?) then (oui)
      :Cliquer "Valider";
      |Systeme|
      :UPDATE payment SET etat = "Complete", valide_par_admin = true;
      :Enregistrer commission + montant prestataire;
      :Creer enregistrement paiement valide;
      :Notifier prestataire "Paiement valide - Gains disponibles";
    else (non - litige)
      :Saisir motif / ouvrir ticket support;
      |Systeme|
      :UPDATE payment SET etat = "Litige";
      :Creer enregistrement Dispute;
      :Notifier client et prestataire;
    endif
  }
end fork

fork again
  partition "Envoi Notifications Globales" {
    :Menu "Notifications / Campagnes";
    :Composer titre + corps du message;
    :Selectionner destinataires (tous clients, tous prestataires, segment specifique, tous utilisateurs);
    :Option : planifier envoi / envoyer immediatement;
    |Systeme|
    :Envoyer via Firebase Cloud Messaging (FCM) uniquement;
    :Enregistrer trace dans table Notification;
  }
end fork

|Admin|
:Deconnexion ou fin de session;
stop

@enduml



