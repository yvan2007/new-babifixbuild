# Variables d'environnement Flutter — Client BABIFIX
# Utilisation : flutter run --dart-define-from-file=.env
# En CI : flutter build apk --dart-define=BABIFIX_API_BASE=https://api.babifix.ci

# URL du backend Django (sans slash final)
BABIFIX_API_BASE=http://10.0.2.2:8002

# URL WebSocket Django Channels (sans slash final)
BABIFIX_WS_BASE=ws://10.0.2.2:8002
